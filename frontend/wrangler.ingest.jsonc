{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sector-radar-ingest",
  "main": "./workers/ingest/index.ts",
  "compatibility_date": "2026-06-24",
  "compatibility_flags": ["nodejs_compat"],
  "triggers": {
    "crons": ["*/15 20-23 * * 1-5", "*/15 0-2 * * 2-6"]
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "vars": {
    "REFRESH_INTERVAL_MINUTES": "15",
    "ENABLE_INTRADAY_CORE_REFRESH": "false",
    "YAHOO_CORE_FETCH_BUDGET": "32",
    "YAHOO_FETCH_BUDGET": "38",
    "YAHOO_HOLDINGS_FETCH_BUDGET": "38",
    "YAHOO_FETCH_CONCURRENCY": "2"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "sector-radar",
      "database_id": "211ed515-584b-405a-98c5-5a781229ee79"
    }
  ]
}
